# Настройки FastAPI
DEBUG=False
MANAGEMENT_API_KEY=YOUR_MANAGEMENT_API_KEY_HERE

# Настройки TeleMT API
TELEMT_API_URL=http://localhost:9095/v1

# Настройки прокси для генерации ссылок
PROXY_HOST=your-domain.com
PROXY_PORT=443
TLS_DOMAIN=ozon.ru

# База данных и Redis
DATABASE_URL=sqlite+aiosqlite:///./telemt_keys.db
REDIS_URL=redis://localhost:6379/0
